ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/collegefootballfantasy
# Keep normal development worktrees on the same Compose project and PostgreSQL volume.
# Override with `COMPOSE_PROJECT_NAME=cff_<purpose>` only for disposable isolated stacks.
COMPOSE_PROJECT_NAME=cff_local
DB_PORT=5433
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=8080
API_LOG_LEVEL=info
UI_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1):[0-9]+
CFBD_API_KEY=
CFBD_BASE_URL=https://api.collegefootballdata.com
ODDS_API_KEY=
ODDS_BASE_URL=https://api.the-odds-api.com/v4
SPORTSDATA_API_KEY=
SPORTSDATA_BASE_URL=https://api.sportsdata.io/v3/cfb
SPORTSDATA_ENABLED=true
SPORTSDATA_PLAYER_STATS_PATH=stats/json/Player/{external_id}
SPORTSDATA_PLAYER_STATS_WEEK_PATH=stats/json/PlayerGameStatsByWeek/{season}/{week}
SPORTSDATA_PLAYERS_PATH=scores/json/Players
SPORTSDATA_SCHEDULE_SEASON_PATH=scores/json/Games/{season}
SPORTSDATA_STANDINGS_PATH=scores/json/Standings/{season}
SPORTSDATA_INJURIES_SEASON_PATH=scores/json/Injuries/{season}
SPORTSDATA_CACHE_TTL_DAYS=30
SPORTSDATA_REFERENCE_TTL_DAYS=30
SPORTSDATA_SCHEDULE_TTL_DAYS=30
SPORTSDATA_STANDINGS_TTL_DAYS=30
SPORTSDATA_INJURY_TTL_DAYS=30
PROVIDER_DEFAULT_CACHE_TTL_DAYS=30
HISTORICAL_STATS_PROVIDER=espn
# Allows manual local ESPN history imports. This does not start a scraper automatically.
ESPN_HISTORICAL_STATS_ENABLED=true
ESPN_HISTORICAL_STATS_BASE_URL=https://site.web.api.espn.com/apis/common/v3/sports/football/college-football
ESPN_HISTORICAL_STATS_TIMEOUT_SECONDS=10
ESPN_HISTORICAL_STATS_MAX_RETRIES=3
ESPN_HISTORICAL_STATS_REQUESTS_PER_SECOND=1
ESPN_HISTORICAL_STATS_CACHE_TTL_DAYS=30
ESPN_HISTORICAL_STATS_SEASONS_BACK=4
ESPN_HISTORICAL_STATS_USER_AGENT=CollegeFootballFantasy/0.1 historical-stats
ESPN_HISTORICAL_STATS_FAIL_OPEN=true
PLAYER_CARD_HISTORICAL_STATS_ENABLED=true
SCORING_PROVIDER=sportsdata
SCORING_ALLOW_UNOFFICIAL_PROVIDERS=false
SCORING_WORKER_INTERVAL_LIVE_SECONDS=60
SCORING_WORKER_INTERVAL_POSTGAME_SECONDS=900
SCORING_WORKER_INTERVAL_CORRECTION_SECONDS=3600
SCORING_WORKER_RETRY_MAX_ATTEMPTS=3
SCORING_WORKER_RETRY_BASE_SECONDS=5
SCORING_DEAD_LETTER_AFTER_FAILURES=3
PROVIDER_UNMATCHED_FAILURE_THRESHOLD_PERCENT=10
FANTASY_SCORING_RULES_JSON=
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_COOKIE_NAME=cfb_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
ALLOW_LEGACY_API_TOKEN_AUTH=false
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_SIGNUP_RATE_LIMIT=5
AUTH_LOGIN_RATE_LIMIT=10
AUTH_REFRESH_RATE_LIMIT=30
AUTH_PASSWORD_RESET_RATE_LIMIT=5
CHAT_MESSAGE_RATE_LIMIT=30
CHAT_MESSAGE_RATE_LIMIT_WINDOW_MINUTES=1
CHAT_MESSAGE_SUSTAINED_RATE_LIMIT=120
CHAT_MESSAGE_SUSTAINED_RATE_LIMIT_WINDOW_MINUTES=15
CHAT_DIRECT_THREAD_RATE_LIMIT=20
CHAT_DIRECT_THREAD_RATE_LIMIT_WINDOW_MINUTES=60
CHAT_READ_RATE_LIMIT=120
CHAT_READ_RATE_LIMIT_WINDOW_MINUTES=1
CHAT_EDIT_WINDOW_MINUTES=15
AUTH_RESEND_VERIFICATION_RATE_LIMIT=5
EMAIL_DELIVERY_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SUPPORT_EMAIL=
PRIVACY_POLICY_URL=
TERMS_URL=
PROVIDER_DISCLOSURE_URL=
SECURITY_HEADERS_ENABLED=true
VITE_SUPPORT_EMAIL=
VITE_PRIVACY_POLICY_URL=
VITE_TERMS_URL=
VITE_PROVIDER_DISCLOSURE_URL=
